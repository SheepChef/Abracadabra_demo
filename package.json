{
  "name": "abracadabra-nodedemo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env BUILD_TARGET=web NODE_OPTIONS=--max-old-space-size=4096 vite",
    "dev:crx": "cross-env BUILD_TARGET=chrome-ext NODE_OPTIONS=--max-old-space-size=4096 vite",
    "build": "cross-env BUILD_TARGET=web NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "build:android": "cross-env BUILD_TARGET=android NODE_OPTIONS=--max-old-space-size=4096 vite build && cd Abracadabra-cordova && cordova build android --release --buildConfig=build.json -- --packageType=apk",
    "build:chrome": "cross-env BUILD_TARGET=chrome-ext NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "build:firefox": "cross-env BUILD_TARGET=firefox-ext NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "build:all": "npm run build && npm run build:android && npm run build:chrome && npm run build:firefox",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@m3e/web": "^2.6.2",
    "@material-symbols/font-400": "^0.45.8",
    "@mdui/icons": "^1.0.4",
    "abracadabra-cn": "^3.5.0",
    "material-symbols": "^0.45.8",
    "mdui": "^2.1.3",
    "patch-package": "^8.0.0",
    "vue": "^3.3.11"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@rushstack/eslint-patch": "^1.3.3",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/eslint-config-prettier": "^9.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.17.0",
    "prettier": "^3.2.4",
    "terser": "^5.31.1",
    "vite": "^5.0.10",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^0.21.0"
  }
}
